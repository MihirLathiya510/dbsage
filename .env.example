# dbsage environment configuration
# Copy this file to .env and fill in your values

# Database connection
DBSAGE_DB_HOST=
DBSAGE_DB_PORT=3306
DBSAGE_DB_NAME=
DBSAGE_DB_USER=
DBSAGE_DB_PASSWORD=
DBSAGE_DB_TYPE=mysql

# Safety guardrails
DBSAGE_MAX_QUERY_ROWS=100
DBSAGE_QUERY_TIMEOUT_MS=10000
DBSAGE_SLOW_QUERY_THRESHOLD_MS=2000
DBSAGE_DEFAULT_SAMPLE_LIMIT=10

# Caching (seconds to cache schema metadata like table lists and column definitions)
DBSAGE_CACHE_TTL_SECONDS=300

# Security (comma-separated table names to hide from LLMs)
DBSAGE_BLACKLISTED_TABLES=[]

# Logging (set to true for human-readable output during development)
DBSAGE_DEV_MODE=false

# Multi-connection passwords
# Add one variable per named connection profile defined in config/connections.json.
# The variable name must match the profile's password_env field — you choose the name.
# PRIMARY_DB_PASSWORD=
# REPLICA_DB_PASSWORD=
# ANALYTICS_DB_PASSWORD=
